  "schemaVersion": 39,
  "tags": ["sre-platform", "openbao", "vault", "secrets"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "SRE / OpenBao Secrets",
  "uid": "sre-openbao",
  "version": 1
