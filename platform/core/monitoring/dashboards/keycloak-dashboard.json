      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "title": "Login Attempts",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(keycloak_login_total[$__rate_interval]))",
          "legendFormat": "Successes",
          "refId": "A"
        },
        {
          "expr": "sum(rate(keycloak_failed_login_attempts_total[$__rate_interval]))",
          "legendFormat": "Failures",
          "refId": "B"
        }
      ]
