    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Namespace" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "CPU Requests (cores)" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "CPU Usage (cores)" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Memory Requests (Gi)" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Memory Usage (Gi)" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "CPU Cost ($)" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Memory Cost ($)" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Total Cost ($)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
