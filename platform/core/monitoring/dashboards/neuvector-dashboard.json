      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Security Events Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(neuvector_security_event_total[$__rate_interval])) by (type)",
