{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["app"],
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "team", "image"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Application name, used for resource naming"
        },
        "team": {
          "type": "string",
          "minLength": 1,
          "description": "Owning team name, used for labels and RBAC"
        },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1,
              "pattern": "^harbor\\.",
              "description": "Container image repository. Must be from internal Harbor registry"
            },
            "tag": {
              "type": "string",
              "minLength": 1,
              "not": { "const": "latest" },
              "description": "Image tag — must be pinned, never latest"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of replicas when autoscaling is disabled"
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command to run (overrides image CMD)"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments to command"
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "secretRef": { "type": "string" }
            }
          }
        },
        "probes": {
          "type": "object",
          "properties": {
            "liveness": {
              "type": "object",
              "properties": {
                "exec": {
                  "type": "object",
                  "properties": {
                    "command": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Command to execute for health check"
                    }
                  },
                  "required": ["command"]
                },
                "initialDelaySeconds": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 10
                },
                "periodSeconds": { "type": "integer" },
                "failureThreshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3
                }
              }
            },
            "readiness": {
              "type": "object",
              "properties": {
                "exec": {
                  "type": "object",
                  "properties": {
                    "command": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Command to execute for readiness check"
                    }
                  },
                  "required": ["command"]
                },
                "initialDelaySeconds": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 5
                },
                "periodSeconds": { "type": "integer" },
                "failureThreshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3
                }
              }
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilization": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string" },
        "port": { "type": "integer" },
        "path": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "additionalEgress": { "type": "array" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 0 }
      }
    },
    "storage": {
      "type": "object",
      "description": "S3-compatible object storage provisioning",
      "properties": {
        "enabled": { "type": "boolean", "default": false, "description": "Enable object storage" },
        "bucket": { "type": "string", "description": "Bucket name (defaults to <team>-<app-name>)" },
        "endpoint": { "type": "string", "description": "S3 endpoint URL (defaults to internal MinIO)" },
        "region": { "type": "string", "description": "Storage region" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Override pod-level security context. Defaults to restricted PSS if not set."
    },
    "containerSecurityContext": {
      "type": "object",
      "description": "Override container-level security context. Defaults to restricted PSS if not set."
    }
  }
}
