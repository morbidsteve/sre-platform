{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["app"],
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "team", "image"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Application name, used for resource naming"
        },
        "team": {
          "type": "string",
          "minLength": 1,
          "description": "Owning team name, used for labels and RBAC"
        },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1,
              "pattern": "^harbor\\.",
              "description": "Container image repository. Must be from internal Harbor registry"
            },
            "tag": {
              "type": "string",
              "minLength": 1,
              "not": { "const": "latest" },
              "description": "Image tag — must be pinned, never latest"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "description": "Image pull policy"
            }
          }
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Container port"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of replicas when autoscaling is disabled"
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "secretRef": { "type": "string" }
            }
          }
        },
        "probes": {
          "type": "object",
          "properties": {
            "liveness": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["http", "tcp", "grpc"],
                  "default": "http",
                  "description": "Probe type: http (httpGet), tcp (tcpSocket), or grpc"
                },
                "path": {
                  "type": "string",
                  "description": "HTTP path for health check (required when type is http)"
                },
                "initialDelaySeconds": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 10
                },
                "periodSeconds": { "type": "integer" },
                "failureThreshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3,
                  "description": "Number of failures before marking probe failed"
                }
              }
            },
            "readiness": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["http", "tcp", "grpc"],
                  "default": "http",
                  "description": "Probe type: http (httpGet), tcp (tcpSocket), or grpc"
                },
                "path": {
                  "type": "string",
                  "description": "HTTP path for health check (required when type is http)"
                },
                "initialDelaySeconds": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 5
                },
                "periodSeconds": { "type": "integer" },
                "failureThreshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3,
                  "description": "Number of failures before marking probe failed"
                }
              }
            }
          }
        },
        "terminationGracePeriodSeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds the pod needs to gracefully shut down"
        },
        "preStopCommand": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command to run before pod termination for graceful shutdown"
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command to run (overrides image CMD)"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments to command"
        }
      }
    },
    "startupProbe": {
      "type": "object",
      "description": "Startup probe for slow-starting apps (JVM, Django, Rails)",
      "properties": {
        "enabled": { "type": "boolean" },
        "type": {
          "type": "string",
          "enum": ["http", "tcp", "grpc"],
          "default": "http",
          "description": "Probe type: http (httpGet), tcp (tcpSocket), or grpc"
        },
        "path": { "type": "string" },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistent storage for stateful apps",
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string" },
        "size": { "type": "string" },
        "storageClass": { "type": "string" },
        "accessModes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "gateway": { "type": "string" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilization": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "allowedServices": {
          "type": "array",
          "description": "Services this app needs to call. Generates NetworkPolicy egress rules.",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "description": "Target service name (matches app.kubernetes.io/name label)" },
              "namespace": { "type": "string", "description": "Target namespace (omit for same namespace)" },
              "port": { "type": "integer", "default": 8080, "description": "Target port" }
            }
          }
        },
        "allowedCallers": {
          "type": "array",
          "description": "Services allowed to call this app. Generates NetworkPolicy ingress rules.",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "description": "Source service name (matches app.kubernetes.io/name label)" },
              "namespace": { "type": "string", "description": "Source namespace (omit for same namespace)" },
              "port": { "type": "integer", "description": "Override ingress port (defaults to app.port)" }
            }
          }
        },
        "additionalIngress": { "type": "array" },
        "additionalEgress": { "type": "array" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 0 }
      }
    },
    "canary": {
      "type": "object",
      "description": "Canary deployment settings (requires Flagger)",
      "properties": {
        "enabled": { "type": "boolean" },
        "progressDeadlineSeconds": { "type": "integer", "minimum": 60 },
        "analysis": {
          "type": "object",
          "properties": {
            "interval": { "type": "string", "description": "How often Flagger runs analysis" },
            "threshold": { "type": "integer", "minimum": 1, "description": "Max failed checks before rollback" },
            "maxWeight": { "type": "integer", "minimum": 1, "maximum": 100, "description": "Max traffic weight to canary" },
            "stepWeight": { "type": "integer", "minimum": 1, "maximum": 100, "description": "Traffic weight step increment" },
            "successRate": { "type": "number", "minimum": 0, "maximum": 100, "description": "Min request success rate percentage" },
            "latencyMax": { "type": "integer", "minimum": 1, "description": "Max request duration in milliseconds" }
          }
        }
      }
    },
    "database": {
      "type": "object",
      "description": "CNPG PostgreSQL database provisioning",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable CNPG PostgreSQL database" },
        "type": {
          "type": "string",
          "enum": ["postgresql"],
          "description": "Database type"
        },
        "instances": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PostgreSQL instances"
        },
        "size": {
          "type": "string",
          "description": "Storage size for the database (e.g. 5Gi)"
        },
        "database": {
          "type": "string",
          "description": "Database name. Defaults to app.name with dashes replaced by underscores"
        },
        "owner": {
          "type": "string",
          "description": "Database owner. Defaults to app.name with dashes replaced by underscores"
        }
      }
    },
    "redis": {
      "type": "object",
      "description": "Redis sidecar provisioning",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable Redis instance" },
        "size": {
          "type": "string",
          "description": "PVC size for Redis persistence (e.g. 1Gi)"
        }
      }
    },
    "migrations": {
      "type": "object",
      "description": "Database migration init container",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable migration init container" },
        "image": {
          "type": "string",
          "description": "Container image for running migrations"
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command to run for migrations"
        }
      }
    },
    "externalServices": {
      "type": "array",
      "description": "Istio ServiceEntry resources for external API access",
      "items": {
        "type": "object",
        "required": ["host"],
        "properties": {
          "host": {
            "type": "string",
            "description": "External service hostname (e.g. api.stripe.com)"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "description": "External service port (default: 443)"
          }
        }
      }
    },
    "websocket": {
      "type": "object",
      "description": "WebSocket support via Istio VirtualService",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable WebSocket routing" },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["uri"],
            "properties": {
              "uri": {
                "type": "string",
                "description": "URI prefix for WebSocket route (e.g. /ws)"
              }
            }
          },
          "description": "WebSocket route URI prefixes"
        }
      }
    },
    "storage": {
      "type": "object",
      "description": "S3-compatible object storage provisioning",
      "properties": {
        "enabled": { "type": "boolean", "default": false, "description": "Enable object storage" },
        "bucket": { "type": "string", "description": "Bucket name (defaults to <team>-<app-name>)" },
        "endpoint": { "type": "string", "description": "S3 endpoint URL (defaults to internal MinIO)" },
        "region": { "type": "string", "description": "Storage region" }
      }
    },
    "sso": {
      "type": "object",
      "description": "SSO / OIDC integration via Keycloak",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable SSO. Adds sre.io/sso annotation which triggers Kyverno to generate Istio JWT auth and OIDC ConfigMap."
        }
      }
    },
    "rateLimit": {
      "type": "object",
      "description": "API rate limiting via Istio EnvoyFilter",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable local rate limiting" },
        "requestsPerSecond": {
          "type": "integer",
          "minimum": 1,
          "description": "Token refill rate per second"
        },
        "burst": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum burst size (token bucket max)"
        }
      }
    },
    "envFrom": {
      "type": "array",
      "description": "Extra envFrom sources (secretRef/configMapRef) to mount as environment variables",
      "items": {
        "type": "object"
      }
    },
    "extraPorts": {
      "type": "array",
      "description": "Additional Service ports beyond app.port",
      "items": {
        "type": "object",
        "required": ["name", "port", "targetPort"],
        "properties": {
          "name": { "type": "string", "description": "Port name" },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"], "default": "TCP" }
        }
      }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes (ConfigMap, Secret, etc.)",
      "items": {
        "type": "object"
      }
    },
    "appProtocol": {
      "type": "string",
      "description": "Application protocol for the main Service port (e.g. grpc, tcp). Empty defaults to http."
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Override pod-level security context. Defaults to restricted PSS if not set."
    },
    "containerSecurityContext": {
      "type": "object",
      "description": "Override container-level security context. Defaults to restricted PSS if not set."
    }
  }
}
