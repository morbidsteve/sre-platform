{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["app"],
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "team", "image"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Application name, used for resource naming"
        },
        "team": {
          "type": "string",
          "minLength": 1,
          "description": "Owning team name, used for labels and RBAC"
        },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1,
              "pattern": "^harbor\\.",
              "description": "Container image repository. Must be from internal Harbor registry"
            },
            "tag": {
              "type": "string",
              "minLength": 1,
              "not": { "const": "latest" },
              "description": "Image tag — must be pinned, never latest"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "description": "Image pull policy"
            }
          }
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Container port the API listens on"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of replicas when autoscaling is disabled"
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "secretRef": { "type": "string" }
            }
          }
        },
        "probes": {
          "type": "object",
          "properties": {
            "liveness": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["http", "tcp"],
                  "default": "http",
                  "description": "Probe type: http (httpGet) or tcp (tcpSocket)"
                },
                "path": {
                  "type": "string",
                  "description": "HTTP path for health check (required when type is http)"
                },
                "initialDelaySeconds": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 10
                },
                "periodSeconds": { "type": "integer" },
                "failureThreshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3,
                  "description": "Number of failures before marking probe failed"
                }
              }
            },
            "readiness": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["http", "tcp"],
                  "default": "http",
                  "description": "Probe type: http (httpGet) or tcp (tcpSocket)"
                },
                "path": {
                  "type": "string",
                  "description": "HTTP path for health check (required when type is http)"
                },
                "initialDelaySeconds": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 5
                },
                "periodSeconds": { "type": "integer" },
                "failureThreshold": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 3,
                  "description": "Number of failures before marking probe failed"
                }
              }
            }
          }
        },
        "terminationGracePeriodSeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds the pod needs to gracefully shut down"
        },
        "preStopCommand": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command to run before pod termination for graceful shutdown"
        }
      }
    },
    "authorizationPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Istio AuthorizationPolicy for caller restrictions"
        },
        "allowedNamespaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["namespace"],
            "properties": {
              "namespace": {
                "type": "string",
                "description": "Namespace allowed to call this API"
              }
            }
          },
          "description": "List of namespaces allowed to call this API"
        },
        "allowedCallers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["namespace"],
            "properties": {
              "namespace": {
                "type": "string",
                "description": "Namespace of the allowed caller"
              },
              "serviceAccounts": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Specific service accounts allowed from this namespace"
              }
            }
          },
          "description": "Fine-grained caller restrictions by namespace and service account"
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilization": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "additionalIngress": { "type": "array" },
        "additionalEgress": { "type": "array" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 0 }
      }
    },
    "database": {
      "type": "object",
      "description": "CNPG PostgreSQL database provisioning",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable CNPG PostgreSQL database" },
        "type": {
          "type": "string",
          "enum": ["postgresql"],
          "description": "Database type"
        },
        "instances": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PostgreSQL instances"
        },
        "size": {
          "type": "string",
          "description": "Storage size for the database (e.g. 5Gi)"
        },
        "database": {
          "type": "string",
          "description": "Database name. Defaults to app.name with dashes replaced by underscores"
        },
        "owner": {
          "type": "string",
          "description": "Database owner. Defaults to app.name with dashes replaced by underscores"
        }
      }
    },
    "redis": {
      "type": "object",
      "description": "Redis sidecar provisioning",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable Redis instance" },
        "size": {
          "type": "string",
          "description": "PVC size for Redis persistence (e.g. 1Gi)"
        }
      }
    },
    "migrations": {
      "type": "object",
      "description": "Database migration init container",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable migration init container" },
        "image": {
          "type": "string",
          "description": "Container image for running migrations"
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command to run for migrations"
        }
      }
    },
    "externalServices": {
      "type": "array",
      "description": "Istio ServiceEntry resources for external API access",
      "items": {
        "type": "object",
        "required": ["host"],
        "properties": {
          "host": {
            "type": "string",
            "description": "External service hostname (e.g. api.stripe.com)"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "description": "External service port (default: 443)"
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "description": "S3-compatible object storage provisioning",
      "properties": {
        "enabled": { "type": "boolean", "default": false, "description": "Enable object storage" },
        "bucket": { "type": "string", "description": "Bucket name (defaults to <team>-<app-name>)" },
        "endpoint": { "type": "string", "description": "S3 endpoint URL (defaults to internal MinIO)" },
        "region": { "type": "string", "description": "Storage region" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Override pod-level security context. Defaults to restricted PSS if not set."
    },
    "containerSecurityContext": {
      "type": "object",
      "description": "Override container-level security context. Defaults to restricted PSS if not set."
    }
  }
}
